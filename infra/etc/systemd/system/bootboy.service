[Unit]
Description=BootBoy boot-time configuration
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/bin/env python3 /home/wombat/github/mellow-wombat/src/bootboy/bootboy.py --admin-dir /var/wombat/admin --status-file /var/wombat/admin/bootboy.status.json
RemainAfterExit=yes

# Hardening note:
# Some environments (notably certain Raspberry Pi/kernel setups) can fail with
# "failed to setup mount namespacing" when mount-namespace-based hardening
# directives are enabled (e.g., ProtectSystem/ProtectHome/PrivateTmp/ReadWritePaths).
# Keep this unit compatible and add hardening only once the target supports it.
NoNewPrivileges=yes

[Install]
WantedBy=multi-user.target
